# ---- Database ----
POSTGRES_USER=suas
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=suas

# ---- Backend ----
# Language model. Leave OPENAI_API_KEY blank to run with deterministic report text.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# API-key gate for /api/plan. Leave blank to disable auth (local only).
API_KEY=

# Comma-separated list of allowed browser origins.
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# ---- Frontend ----
# Browser-reachable backend URL. Baked into the client bundle at build time.
NEXT_PUBLIC_API_URL=http://localhost:8000
